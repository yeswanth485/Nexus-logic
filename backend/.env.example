# Backend environment variables
# ─────────────────────────────────────────────────────────
# The port Render assigns automatically (do not change)
PORT=3000

# Set this to your Vercel frontend URL after deploying
# Example: https://nexus-logix.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Firebase Admin credentials (if using Firebase Admin SDK)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY=your_private_key

# Gemini AI key (server-side usage)
GEMINI_API_KEY=your_gemini_api_key

# Database connection string (if using Postgres/Supabase)
# DATABASE_URL=postgres://user:password@host:port/dbname
